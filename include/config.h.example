// Copy this file to config.h and fill in your values.
// config.h is git-ignored — your credentials stay local.

#define WIFI1_SSID      "your-home-wifi-ssid"
#define WIFI1_PASS      "your-home-wifi-password"
#define WIFI2_SSID      "your-work-wifi-ssid"
#define WIFI2_PASS      "your-work-wifi-password"

// Google Apps Script calendar proxy URL:
//   Deploy apps_script/calendar.js as a web app, then paste the URL
//   with your secret token appended, e.g. ...exec?token=MY_SECRET
#define APPS_SCRIPT_URL "https://script.google.com/macros/s/YOUR_DEPLOY_ID/exec?token=YOUR_SECRET"

// POSIX timezone string — find yours at:
// https://github.com/nayarsystems/posix_tz_db/blob/master/zones.csv
#define TIMEZONE        "MST7MDT,M3.2.0/2,M11.1.0/2"

// Display rotation (1 = portrait with USB at bottom)
#define DISPLAY_ROTATION 1
